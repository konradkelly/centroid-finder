: "${PWD:?must be run from project root}"

export VIDEOS_DIR="$PWD/videos"
export RESULTS_DIR="$PWD/results"
export VIDEO_PROCESSOR_JAR="$PWD/target/centroid-finder-1.0-SNAPSHOT-jar-with-dependencies.jar"

export SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/centroidfinder
export SPRING_DATASOURCE_USERNAME=postgres
export SPRING_DATASOURCE_PASSWORD=postgres

export JOB_TIMEOUT=PT10M

PROJECT_ROOT="$PWD"

VIDEOS_DIR="$PROJECT_ROOT/sampleInput"
RESULTS_DIR="$PROJECT_ROOT/results"
VIDEO_PROCESSOR_JAR="$PROJECT_ROOT/target/centroid-finder-1.0-SNAPSHOT-jar-with-dependencies.jar"

SPRING_DATASOURCE_URL="jdbc:postgresql://localhost:5433/centroidfinder"
SPRING_DATASOURCE_USERNAME="postgres"
SPRING_DATASOURCE_PASSWORD="postgres"

JOB_TIMEOUT="PT10M"